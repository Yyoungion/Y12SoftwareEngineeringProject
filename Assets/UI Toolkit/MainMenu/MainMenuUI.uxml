<ui:UXML xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements" noNamespaceSchemaLocation="../../UIElementsSchema/UIElements.xsd" editor-extension-mode="False">
    <Style src="project://database/Assets/UI%20Toolkit/MainMenu/MenuStyles.uss?fileID=7433441132597879392&amp;guid=f764a68ac73da34498587fe4181e97a3&amp;type=3#MenuStyles"/>
    <ui:VisualElement name="Container" style="flex-grow: 1; width: 100%; height: 100%; background-color: rgb(0, 22, 178);">
        <ui:Label text="SURVIVAL GAME" name="Title" class="title" style="font-size: 72px; color: rgb(255, 255, 255); -unity-font-style: bold; align-items: center; justify-content: center; width: 100%; height: 150px; margin-top: 100px; -unity-text-align: upper-center; -unity-font-definition: url(&quot;project://database/Library/unity%20default%20resources?fileID=10102&amp;guid=0000000000000000e000000000000000&amp;type=0#LegacyRuntime&quot;);"/>
        <ui:Button text="PLAY" name="PlayButton" class="play-button" style="width: 300px; height: 80px; align-self: center; margin-top: 50px; background-color: rgb(50, 200, 100); font-size: 36px; color: rgb(255, 255, 255); -unity-font-style: bold; border-top-left-radius: 10px; border-top-right-radius: 10px; border-bottom-right-radius: 10px; border-bottom-left-radius: 10px; border-top-width: 2px; border-right-width: 2px; border-bottom-width: 2px; border-left-width: 2px; border-left-color: rgb(6, 101, 0); border-right-color: rgb(6, 101, 0); border-top-color: rgb(6, 101, 0); border-bottom-color: rgb(6, 101, 0);"/>
        <ui:Button text="OPTIONS" name="OptionsButton" class="options-button" style="width: 300px; height: 80px; align-self: center; margin-top: 20px; background-color: rgb(80, 120, 200); font-size: 36px; color: rgb(255, 255, 255); -unity-font-style: bold; border-top-left-radius: 10px; border-top-right-radius: 10px; border-bottom-right-radius: 10px; border-bottom-left-radius: 10px; border-top-width: 2px; border-right-width: 2px; border-bottom-width: 2px; border-left-width: 2px; border-left-color: rgb(1, 0, 115); border-right-color: rgb(1, 0, 115); border-top-color: rgb(1, 0, 115); border-bottom-color: rgb(1, 0, 115);"/>
    </ui:VisualElement>
</ui:UXML>
